{
  "rewrites": [
    {
      "source": "/blogs/:blogId",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Pinterest|redditbot|SkypeUriPreview|vkShare|Applebot).*"
        }
      ],
      "destination": "/api/share/:blogId"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
